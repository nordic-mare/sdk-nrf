menu "Sensors"

config ENVIRONMENT_SENSOR
	bool "Enable environment sensor"

if ENVIRONMENT_SENSOR
choice
	prompt "Environment sensor device"
	default ENV_SENSOR_USE_EXTERNAL

config ENV_SENSOR_USE_EXTERNAL
	bool "Use the BME680 environment sensor"
	depends on BME680

config ENV_SENSOR_USE_SIM
	bool "Simulate environment sensor"
	depends on SENSOR_SIM
	help
		Use sensor simulator to generate data.
		Gas resistance is not supported by the sensor simulator,
		and gas_res_read() will return an unchanged value.
endchoice # Environment sensor device

if ENV_SENSOR_USE_SIM
config ENV_SENSOR_GAS_RES_SIM_VAL
	int "Simulated gas resistance value"
	default 10000
	help
		Gas resistance in Ohm that will be
		returned when the environment sensor is simulated,
		as the sensor simulator does not have generic sensor
		support.
endif # ENV_SENSOR_USE_SIM
endif # ENVIRONMENT_SENSOR

config ACCELEROMETER
	bool "Enable accelerometer"

if ACCELEROMETER
choice 
	prompt "Accelerometer device"
	default ACCEL_USE_EXTERNAL

config ACCEL_USE_EXTERNAL
	bool "Use the ADXL362 accelerometer"
	depends on ADXL362

config ACCEL_USE_SIM
	bool "Simulate accelerometer"
	depends on SENSOR_SIM
	help
		Use sensor simulator to generate accelerometer data.
endchoice # Accelerometer device

config ACCEL_CALIBRATE
	bool "Calibrate the accelerometer on startup"
	default y
	help
		Calibrate the accelerometer on a flat surface to filter away
		static measurement offset that could affect orientation
		detection.

config ACCEL_CALIBRATION_ITERATIONS
	int "Number of measurements per channel during calibration"
	default 5
endif # ACCELEROMETER


config LIGHT_SENSOR
    bool "Enable light sensor"

if LIGHT_SENSOR
choice 
	prompt "Light sensor device"
	default LIGHT_SENSOR_USE_EXTERNAL

config LIGHT_SENSOR_USE_EXTERNAL
	bool "Use the BH1749 light sensor"
	depends on BH1749
	depends on UI_SENSE_LED

config LIGHT_SENSOR_USE_SIM
	bool "Simulate light sensor"
endchoice # Light sensor device

config LIGHT_SENSOR_LIGHT_MEASUREMENT_MAX_VALUE
    int "Max expected light sensor output value"
	default 500
	help
		Maximum value expected from the light sensor.
		Used to scale each color measurement to an 8-bit, unsigned
		integer. 
		Reasonable values will depend on the sensors environment.
		Max of a series of raw measurements during particular use conditions
		can give a good estimate (for that condition).

config LIGHT_SENSOR_COLOUR_MEASUREMENT_MAX_VALUE
	int "Max expected colour sensor output value"
	default 500
	help
		Maximum value expected from the colour sensor. 
		Used to scale each color measurement to an 8-bit, unsigned
		integer. 
		Reasonable values will depend on the sensors environment.
		Max of a series of raw measurements during particular use conditions
		can give a good estimate (for that condition).

if LIGHT_SENSOR_USE_SIM
config LIGHT_SENSOR_LIGHT_SIM_VAL
	int "Simulated light value for all channels"
	default 50
	help
		Simulated light value. Wil be scaled to 
		uint8_t, so this value should be smaller than
		LIGHT_SENSOR_LIGHT_MEASUREMENT_MAX_VALUE. 

config LIGHT_SENSOR_COLOUR_SIM_VAL
	int "Simulated colour value for all channels"
	default 250
	help
		Simulated colour value. Wil be scaled to 
		uint8_t, so this value should be smaller than
		LIGHT_SENSOR_COLOUR_MEASUREMENT_MAX_VALUE. 
endif # LIGHT_SENSOR_USE_SIM
endif # LIGHT_SENSOR
endmenu # Sensors