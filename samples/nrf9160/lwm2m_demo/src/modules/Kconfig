menu "Light minimum change"

config SENSOR_MODULE_LIGHT_DELTA_R
	int "Variation in red light required to register a measurement."
	range 0 255
	default 50
	help
		Required difference in red light to register a new measurement.
		Set this to 0 to always register the latest measurement.

config SENSOR_MODULE_LIGHT_DELTA_G
	int "Variation in green light required to register a measurement."
	range 0 255
	default 50
	help
		Required difference in green light to register a new measurement.
		Set this to 0 to always register the latest measurement.

config SENSOR_MODULE_LIGHT_DELTA_B
	int "Variation in blue light required to register a measurement."
	range 0 255
	default 50
	help
		Required difference in blue light to register a new measurement.
		Set this to 0 to always register the latest measurement.

config SENSOR_MODULE_LIGHT_DELTA_IR
	int "Variation in infrared light required to register a measurement."
	range 0 255
	default 50
	help
		Required difference in infrared light to register a new measurement.
		Set this to 0 to always register the latest measurement.

endmenu # Light minimum change

