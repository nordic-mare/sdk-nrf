menu "Modules"

menu "Sensor Module"

config SENSOR_MODULE_TEMP_DELAY
	int "Delay between temperature readings"
	default 120
	help
		Time in seconds before a new temperature work is submitted to the
		system work queue. Actual delay between temperature sensor
		reads will vary on the execution time of the other works 
		in the queue at the time the temperature work is submitted.

config SENSOR_MODULE_TEMP_DELTA_INT
	int "Variation in temperature required to register a measurement. Integer part."
	default 1
	help
		Required difference in temperature to register a new measurement.
		Unit is degrees Celsius. 
		Set this and the decimal part to 0 to always register the latest measurement.

config SENSOR_MODULE_TEMP_DELTA_DEC
	int "Variation in temperature required to register a measurement. Decimal part."
	default 0
	help
		Required difference in temperature to register a new measurement.
		Unit is decimal part of degrees Celsius. 
		Divide by 1E6 to get actual decimal value. 
		Set this and the integer part to 0 to always register the latest measurement.

config SENSOR_MODULE_PRESS_DELAY
	int "Delay between pressure readings"
	default 120
	help
		Time in seconds before a new pressure work is submitted to the
		system work queue. Actual delay between pressure sensor
		reads will vary on the execution time of the other works 
		in the queue at the time the pressure work is added.
	
config SENSOR_MODULE_PRESS_DELTA_INT
	int "Variation in pressure required to register a measurement"
	default 0
	help
		Required difference in pressure to register a new measurement.
		Unit is kilo Pascal. 
		Set this and the decimal part to 0 to always register the latest measurement.

config SENSOR_MODULE_PRESS_DELTA_DEC
	int "Variation in pressure required to register a measurement"
	default 5000
	help
		Required difference in pressure to register a new measurement.
		Unit is decimal part of kilo Pascal.
		Divide by 1E6 to get actual decimal value. 
		Set this and the integer part to 0 to always register the latest measurement.

