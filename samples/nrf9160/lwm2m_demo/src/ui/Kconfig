menu "User Interface"

config UI_LED
	bool "Enable LEDs"

if UI_LED
choice
	prompt "LED device"
	default UI_LED_USE_GPIO
	help
	  Select which device is used for controlling
	  the LEDs.

config UI_LED_USE_PWM
	bool "Use PWM to control LEDs"
	select PWM 
	select PWM_0
	help
		If enabled, LEDs will be controlled with PWM.

config UI_LED_USE_GPIO
	bool "Use GPIO to control LEDs"
	help
		If enabled, LEDs will be controlled with GPIO. 
endchoice # LED device
endif # UI_LED


config UI_BUZZER
	bool "Enable buzzer"
	select PWM
	select PWM_1
	help
		If enabled, a buzzer will be controllable with PWM. 


config UI_INPUT
	bool "Enable switches and buttons"


config UI_SENSE_LED
	bool "Enable sense LEDs"
	help
		Enables the sense LEDs available on the Thingy:91.

endmenu # User Interface

module = UI
module-str = User Interface
source "${ZEPHYR_BASE}/subsys/logging/Kconfig.template.log_config"