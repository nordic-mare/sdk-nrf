menu "LWM2M IPSO app"

config LWM2M_IPSO_APP_BUZZER
    bool "Enable IPSO Buzzer support"
    default y if BOARD_THINGY91_NRF9160NS
    default n if BOARD_NRF9160DK_NRF9160NS
    help
        This IPSO object is used to actuate an audible alarm such as a buzzer,
	    beeper, or vibration alarm.

config LWM2M_IPSO_APP_BUZZER_INSTANCE_COUNT
    int "Maximum # of buzzer object instances"
	default 1
	depends on LWM2M_IPSO_APP_BUZZER
	help
        Total count of IPSO Buzzer instances
        available to the LWM2M client.


config LWM2M_IPSO_APP_COLOUR_SENSOR
    bool "Enable IPSO Colour sensor support"
    default y
    help
        This IPSO object should be used to report the measured value of a 
        colour sensor in some colour space described by the units resource.

config LWM2M_IPSO_APP_COLOUR_SENSOR_INSTANCE_COUNT
	int "Number of colour sensors present on board"
	default 1
    depends on LWM2M_IPSO_APP_COLOUR_SENSOR
	help
        Total count of IPSO Colour instances
        available to the LWM2M client.

choice
	prompt "IPSO Colour object version"
	depends on LWM2M_IPSO_APP_COLOUR_SENSOR
	default LWM2M_IPSO_APP_COLOUR_SENSOR_VERSION_1_0
	help
	  Select which version of the IPSO Colour object should be used.

config LWM2M_IPSO_APP_COLOUR_SENSOR_VERSION_1_0
	bool "IPSO Colour object version 1.0"

config LWM2M_IPSO_APP_COLOUR_SENSOR_VERSION_1_1
	bool "IPSO Colour object version 1.1"
endchoice

endmenu # LWM2M ipso app
